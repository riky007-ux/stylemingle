# Example environment variables for StyleMingle app
OPENAI_API_KEY=your-openai-api-key
TURSO_DATABASE_URL=your-turso-database-url
TURSO_AUTH_TOKEN=your-turso-auth-token
NEXTAUTH_SECRET=some-secret
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Gate 13 visual awareness feature flag (default OFF)
VISUAL_AWARENESS_ENABLED=0
NEXT_PUBLIC_VISUAL_AWARENESS_ENABLED=0

# Gate 13 preview-only deterministic proof mode (default OFF; ignored in production)
VISUAL_AWARENESS_PROOF_MODE=0
NEXT_PUBLIC_VISUAL_AWARENESS_PROOF_MODE=0
